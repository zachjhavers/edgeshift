# MLB engine (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost/mlb_model

# The Odds API — used by both MLB and NHL engines
ODDS_API_KEY=your_key_here

# Frontend CORS (comma-separated)
ALLOWED_ORIGINS=https://your-domain.vercel.app

# Email (optional — set SEND_EMAIL=1 to enable)
SEND_EMAIL=0
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
